{
    "app": {
        "name": "DPRS",
        "version": "1.0.0",
        "environment": "development"
    },
    "logging": {
        "level": "INFO",
        "file": "logs/app.log",
        "max_bytes": 10485760,
        "backup_count": 7
    },
    "data": {
        "input_dir": "input",
        "output_dir": "output",
        "sample_csv": "input/sample_data.csv",
        "sample_json": "input/sample_data.json",
        "schema_validation": true
    },
    "reporting": {
        "default_format": "text",
        "save_to_file": true,
        "report_dir": "output/reports"
    }
}